{
  "processors": [
    {
      "enrich": {
        "ignore_failure": true,
        "policy_name": "opensky-geo-enrich-50m",
        "ignore_missing": true,
        "field": "location",
        "target_field": "geo"
      }
    },
    {
      "enrich": {
        "ignore_failure": true,
        "policy_name": "adsb-airport-proximity",
        "ignore_missing": true,
        "field": "location",
        "target_field": "airport"
      }
    },
    {
      "convert": {
        "field": "on_ground",
        "type": "boolean",
        "ignore_missing": true
      }
    },
    {
      "convert": {
        "field": "velocity",
        "type": "float",
        "ignore_missing": true
      }
    },
    {
      "convert": {
        "field": "vertical_rate",
        "type": "float",
        "ignore_missing": true
      }
    },
    {
      "script": {
        "if": "ctx.airport != null",
        "lang": "painless",
        "source": "if (ctx.on_ground == true) { if (ctx.velocity != null && ctx.velocity == 0) { ctx.airport.activity = 'at_airport'; } else { ctx.airport.activity = 'taxiing'; } } else if (ctx.vertical_rate != null && ctx.vertical_rate < -2.0) { ctx.airport.activity = 'arriving'; } else if (ctx.vertical_rate != null && ctx.vertical_rate > 2.0) { ctx.airport.activity = 'departing'; } else { ctx.airport.activity = 'overflight'; }"
      }
    },
    {
      "remove": {
        "ignore_failure": true,
        "ignore_missing": true,
        "field": ["geo.geometry", "airport.geo.airspace", "data_stream"]
      }
    },
    {
      "trim": {
        "ignore_failure": true,
        "ignore_missing": true,
        "field": "callsign"
      }
    }
  ]
}
