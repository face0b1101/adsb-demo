# Elastic Stack
ELASTIC_STACK_VERSION=9.3.1

# Docker — set to . if running from this repo root
DOCKER_HOME=.

# Logstash settings
LS_PIPELINE_WORKERS=2
LS_LOG_LEVEL=info
LS_MONITORING_ENABLED=false
LS_MONITORING_CLUSTER_UUID=

# Logstash monitoring API credentials (port 9600) — user-chosen, not issued by Elasticsearch
LS_API_USER=logstash
LS_API_PW=changeme

# Elasticsearch — endpoint URL and API key (works with Cloud, Serverless, and start-local)
# The API key needs: cluster monitor, index CRUD on demos-*, and Kibana feature privileges
# for Saved Objects, Agent Builder, Workflows, Actions, Advanced Settings, and
# Security Solution Cases. See README.md "Generate an API Key" for the full role descriptor.
ES_ENDPOINT=
ES_API_KEY_ID=
ES_API_KEY=
ES_API_KEY_ENCODED=

# Kibana endpoint
KB_ENDPOINT=

# OpenSky Network API
OPENSKY_API_USER=
OPENSKY_API_PW=

# Slack — incoming webhook URL for the daily briefing workflow (optional)
# Create a Slack app with an incoming webhook: https://api.slack.com/messaging/webhooks
# If set, setup.sh creates the Kibana Slack connector automatically.
# If not set, configure the connector manually in Kibana > Stack Management > Connectors.
SLACK_WEBHOOK_URL=

# RapidAPI — key for the Reuters news search in the hijack investigation workflow (optional)
# Sign up at https://rapidapi.com and subscribe to the Reuters API.
# If not set, the workflow skips the news correlation step gracefully.
RAPIDAPI_KEY=
